# show available recipes
default:
    @just --list

# run code formatter
format *args:
    uvx ruff format {{ args }} ./src/ ./tests/

# run code style checks
style *args:
    uvx ruff check --config ../ruff.toml {{ args }} ./src/ ./tests/

# run unit tests
test:
    uvx pytest -v -p no:cacheprovider --disable-warnings ./tests/

# clean workdir
clean:
    rm -rf ./.pytest_cache ./build ./dist ./src/*.egg-info
