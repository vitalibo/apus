# show available recipes
default:
    @just --list

# run code formatter
format *args:
    uv run ruff format {{ args }} ./src/ ./tests/

# run code style checks
check *args:
    uv run ruff check --config ../ruff.toml {{ args }} ./src/ ./tests/

# run unit tests
test *args:
    uv run -m pytest -v -p no:cacheprovider --disable-warnings {{ args }} ./tests/

# run unit tests with coverage
coverage *args:
    just test --cov=apus_cli --cov-branch {{ args }}

# build # build package
build *args:
    mkdir -p ./lib
    for module in shared api monitoring; do ln -s ../../apus-$module/src/apus_$module ./lib/apus_$module ; done
    uv build --sdist --wheel {{ args }}
    rm -rf ./lib

# clean workdir
clean:
    rm -rf ./.pytest_cache ./build ./dist ./src/*.egg-info ./.coverage ./lib
