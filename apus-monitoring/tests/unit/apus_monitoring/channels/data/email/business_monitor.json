{
  "apiVersion": "apus/v1",
  "kind": "BusinessMonitor",
  "metadata": {
    "name": "MyMonitor",
    "annotations": {
      "description": "This is a business monitor for testing purposes."
    }
  },
  "spec": {
    "schedule": "* */6 * * ? *",
    "connection": {
      "engine": "postgresql",
      "username": "test",
      "host": "localhost",
      "password": "123",
      "port": 5432,
      "database": "mydb"
    },
    "metric": {
      "name": "Metric #1",
      "field": "metric1"
    },
    "dimensions": [
      "dim1",
      {
        "dim2": {
          "name": "Dimension #2"
        }
      },
      {
        "field": "dim3",
        "name": "Dimension #3",
        "description": "This is dimension three"
      }
    ],
    "query_template": "SELECT * FROM foo",
    "channels": [
      {
        "type": "email",
        "host": "smtp.example.com",
        "port": 587,
        "username": "test",
        "password": "123",
        "recipients": [
          "vitalibo@apus.io"
        ]
      }
    ]
  }
}
